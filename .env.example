# ============================================================
# Firebird Bridge - variaveis de ambiente
# Copie este arquivo para ".env" e preencha com os valores reais.
# (o .env ja esta no .gitignore e nao vai pro repositorio)
# ============================================================

# Host/IP do servidor Firebird (ex.: 201.20.35.230)
FIREBIRD_HOST=

# Porta do Firebird (padrao 3050)
FIREBIRD_PORT=3050

# Caminho/alias do banco no servidor
# Windows: E:\FTPBackup\Integracao\SPOSASCO.DATAWEB.CERT
FIREBIRD_DATABASE=

# Usuario (padrao SYSDBA)
FIREBIRD_USER=SYSDBA

# Senha
FIREBIRD_PASSWORD=

# Charset (padrao WIN1252)
FIREBIRD_CHARSET=WIN1252

# Porta HTTP da API (opcional, padrao 3000)
PORT=3000
